# ─────────────────────────────────────────────────────────────
# SecureNaija — environment template. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# ---- Postgres ----
POSTGRES_USER=securenaija
POSTGRES_PASSWORD=securenaija_dev_password
POSTGRES_DB=securenaija
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- API ----
# Full SQLAlchemy URL. In Docker, host is the compose service name `db`.
DATABASE_URL=postgresql+psycopg://securenaija:securenaija_dev_password@db:5432/securenaija
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# ---- Security ----
# Generate a real one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS ----
# Comma-separated allowed origins. In production add your Vercel domain, e.g.
# CORS_ORIGINS=https://securenaija.vercel.app,https://www.securenaija.ng
CORS_ORIGINS=http://localhost:3000

# ---- ML ----
# Model registry dir. Baked into the API image at /models (no mount needed).
MODEL_REGISTRY_DIR=/models

# ---- Continuous learning ----
# Durable dir for user feedback (mounted volume in Docker / Railway). Retraining
# reads the SAME path, so corrections actually reach the next training run.
FEEDBACK_DIR=/data/feedback

# ---- Rate limiting ----
# In-memory by default; point at Redis to share limits across replicas.
# RATELIMIT_STORAGE_URI=redis://default:pass@host:6379

# ---- Web (Next.js) ----
# In production this is your Railway API URL, e.g. https://securenaija-api.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# LOCAL DEV WITHOUT DOCKER: use SQLite (no Postgres needed):
#   DATABASE_URL=sqlite:///./apps/api/securenaija_dev.db
# ─────────────────────────────────────────────────────────────
